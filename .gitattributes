# Normalize text files with LF to avoid platform-dependent line ending warnings.
* text=auto eol=lf

# Keep Windows shell scripts with CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
