# .gitignore para projeto .NET / C#

# Build Folders
bin/
obj/
obj-alt/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
.vs/
*.user
*.userosscache
*.suo
*.sdf
*.cachefile
*.dbmdl
*.bak
# Rider
.idea/
*.sln.iml

# Visual Studio Code settings
.vscode/

# NuGet
*.nupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# DotCover
*.dotCover

# MSTest test results
/TestResults/

# NCrunch
*.crunch*
_NCrunch_*

# Build results
*.dll
*.exe
*.app
*.appx
*.apk
*.unitypackage
*.ipa
*.nupkg
*.symbols.nupkg
*.psess
*.vsp
*.vspx
*.coverage
*.coveragexml

# Backup & report files
logs/
*.log
*.vsmdi
*.vsscc
*_i.c
*_p.c
*_h.h
*.bak
*.tmp
*.tmp_proj
*.log
~$*

# Rider
.idea/
*.sln.iml

# OS generated files
ehthumbs.db
Thumbs.db

# Windows image file caches
*.stackdump

# User-specific files
*.swp
*~

# SQLite database files (opcional: mantenha se for fonte de dados de exemplo)
*.db
*.sqlite

# Publish
default发布文件夹/publish/
publish/

# JetBrains Rider local history
.idea/

# Temporary folders
*.tmp
*.temp

# Lock files
*.lock.json

# The following lines are safe defaults for .NET source-generators
# and related bin/obj directories in nested projects.
**/bin/
**/obj/
